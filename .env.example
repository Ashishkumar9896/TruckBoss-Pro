# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Option 1: Individual Variables)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=trucks
DB_PORT=3306
DB_SSL=false

# Database Configuration (Option 2: Connection String - for Render/Railway/etc)
# DATABASE_URL=mysql://user:pass@host:port/dbname

# Security & Auth
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRES_IN=7d
FRONTEND_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=100
API_RATE_LIMIT_MAX=2000

# Cloudinary Storage (for maintenance proofs)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_PROOF_FOLDER=bihal-suppliers/maintenance-proofs

# Infrastructure Utilities
# Linux/Render: /usr/bin/mysqldump
# Windows: C:\Program Files\MySQL\MySQL Server 9.x\bin\mysqldump.exe
MYSQLDUMP_PATH=mysqldump
